{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autonomous-fleet.dev/schemas/fleet-trace.schema-1.1.json",
  "title": "Autonomous Fleet — trace event (v1.1)",
  "description": "v1.1 adds optional causal-lifeline `id` on every event. Consumers that pin 1.0 remain valid — `id` was already generated at runtime but omitted from the 1.0 JSON Schema. New consumers SHOULD pin 1.1 when wiring parent_event chains.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "ts",
    "run_id",
    "mission",
    "primitive",
    "role",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.1",
      "description": "Schema 1.1 — optional id field formalized for causal lifelines."
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Optional unique event id. Always generated by TraceEmitter; consumers use it for parent_event linkage."
    },
    "ts": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[0-9]{8}T[0-9]{6}Z-[a-z][a-z0-9-]*[a-z0-9]-[0-9a-f]{6}$"
    },
    "mission": {
      "type": "string",
      "minLength": 1
    },
    "primitive": {
      "type": "string",
      "enum": [
        "SPAWN_WORKER",
        "DISPATCH",
        "WAIT",
        "INSPECT",
        "SYNC",
        "MERGE",
        "FREEZE",
        "T-FINAL",
        "GOAL_BLOCKED",
        "COMMIT",
        "ABORT"
      ]
    },
    "role": {
      "type": "string",
      "enum": [
        "COORDINATOR",
        "BUILDER",
        "REVIEWER",
        "INTEGRATOR",
        "FIXER",
        "OTHER"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "started",
        "succeeded",
        "failed",
        "blocked",
        "skipped"
      ]
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "evidence_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "cost_delta": {
      "type": "number",
      "minimum": 0
    },
    "parent_event": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "details": {
      "type": "object",
      "additionalProperties": true
    }
  }
}